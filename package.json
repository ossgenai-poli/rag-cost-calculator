{
  "name": "rag-cost-calculator",
  "version": "1.0.0",
  "private": true,
  "description": "AWS RAG Price Calculator — engineer-mode cost estimator for Retrieval-Augmented-Generation pipelines on AWS",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:static": "cross-env STATIC_EXPORT=true next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "refresh-prices": "tsx scripts/refresh-prices.ts",
    "serve:static": "npx serve out -l 3100",
    "test:e2e": "node scripts/verify-e2e.mjs",
    "verify:live": "node scripts/verify-live.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-pricing": "^3.700.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.17",
    "puppeteer-core": "^23.11.1",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.17"
  }
}
