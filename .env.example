# AWS read-only credentials for the live Pricing API route (Vercel env vars /
# GitHub Actions secrets ONLY — never commit real values).
# IAM policy must be limited to: pricing:GetProducts
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# GitHub Pages project-subpath hosting, e.g. /rag-cost-calculator
NEXT_PUBLIC_BASE_PATH=
